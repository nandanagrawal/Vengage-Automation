DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/vengage

# Local customer file uploads (relative to API process cwd unless absolute)
CUSTOMER_ATTACHMENTS_DIR=data/customer_attachments

ALLOWED_ORIGINS=http://localhost:3000

# Auth — change JWT_SECRET to a long random string before going to production
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=480

QBO_ENVIRONMENT=sandbox
QBO_MINOR_VERSION=65
QBO_REALM_ID=
QBO_INVOICE_TEMPLATE_ID=

# Intuit OAuth — redirect_uri in authorize request MUST match a URI listed here character-for-character:
# Developer Portal → Your app → Keys & OAuth (Development section for sandbox) → Redirect URIs → Add URI.
#
# Recommended (this repo mounts OAuth here):
QBO_REDIRECT_URI=http://localhost:8000/api/auth/callback
#
# Alternative if you already registered the older path (still supported by the API):
# QBO_REDIRECT_URI=http://localhost:8000/api/v1/auth/qbo/callback
#
# Rules: use http + localhost only for local dev; no trailing slash; port must match uvicorn (8000).
# If you open the app via 127.0.0.1, register http://127.0.0.1:8000/api/auth/callback instead and use that here.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000

# OAuth troubleshooting — if Intuit shows “didn’t connect” after /api/auth/connect:
# 1) Open GET http://localhost:8000/api/auth/oauth-check and compare redirect_uri to Intuit Developer → Keys & OAuth → Redirect URIs (exact string; localhost ≠ 127.0.0.1).
# 2) Use Development / Sandbox Client ID + Secret for sandbox companies (not Production keys).
# 3) On Intuit’s error page expand “View error details” — e.g. redirect_uri_mismatch confirms (1).
#
# Token file (same idea as vengage-poc/backend/tokens.py): default is ../tokens.json → repo-root tokens.json.
# The file is written ONLY after OAuth succeeds (browser hits /api/auth/callback). See GET /api/auth/oauth-check → token_file_path.
TOKEN_FILE_PATH=

QBO_ACCESS_TOKEN=

# Optional dev webhook verification
INTUIT_WEBHOOK_VERIFIER_TOKEN=
